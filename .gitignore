# ======================================
# BUILD DIRECTORIES AND ARTIFACTS 
# (Generated by CMake, Makefiles, etc.)
# ======================================
/build
/out
*.o             # Object files
*.exe            # Compiled executables
*.obj            # Object libraries

# If you use specific build folders like Debug or Release:
/Debug
/Release


# ======================================
# IDE AND EDITOR CONFIG FILES 
# (These contain user-specific settings and should not be tracked)
# ======================================
.vscode/             # VS Code workspace data
.idea/               # IntelliJ / PhpStorm data
*.suo                # Visual Studio Solution User Options
*.user               # Visual Studio user profile files

# Windows temporary system files
Thumbs.db
ehthumbs.db


# ======================================
# SOURCE FILES (If you use external headers)
# This is only necessary if you download third-party libraries 
# that are not part of your core project structure.
# ======================================
# *.h_generated*
